{
  "name": "paste",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/bun": "^1.3.14",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.7",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2",
      "tailwind-merge": "^3.6.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter='!desktop' && turbo run build -F desktop",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev -F web",
    "dev:desktop": "turbo run dev:hmr -F desktop",
    "build:desktop": "turbo run build:stable -F desktop",
    "build:desktop:canary": "turbo run build:canary -F desktop"
  },
  "dependencies": {
    "@paste/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@paste/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "^22.13.14",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.9"
}
